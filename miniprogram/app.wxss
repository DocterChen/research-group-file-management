/* app.wxss - 全局样式 */
page {
  background-color: #f8f9fa;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', 'Helvetica Neue', Helvetica, Arial, sans-serif;
  font-size: 28rpx;
  color: #333333;
  line-height: 1.6;
}

/* 通用容器 */
.container {
  padding: 32rpx;
}

/* 卡片样式 */
.card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

/* 按钮样式 */
.btn-primary {
  background-color: #0ea5e9;
  color: #ffffff;
  border: none;
  border-radius: 12rpx;
  padding: 24rpx 48rpx;
  font-size: 32rpx;
  font-weight: bold;
}

.btn-primary:active {
  background-color: #0284c7;
}

.btn-secondary {
  background-color: #e5e7eb;
  color: #333333;
  border: none;
  border-radius: 12rpx;
  padding: 24rpx 48rpx;
  font-size: 32rpx;
}

.btn-secondary:active {
  background-color: #d1d5db;
}

/* 输入框样式 */
.input-group {
  margin-bottom: 32rpx;
}

.input-label {
  display: block;
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 12rpx;
}

.input-field {
  background-color: #f8f9fa;
  border: 2rpx solid #e5e7eb;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 30rpx;
  width: 100%;
  box-sizing: border-box;
}

.input-field:focus {
  border-color: #0ea5e9;
}

/* 标题样式 */
.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #111827;
  margin-bottom: 16rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #6b7280;
  margin-bottom: 32rpx;
}

/* 列表样式 */
.list-item {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

/* 标签样式 */
.tag {
  display: inline-block;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  margin-right: 12rpx;
}

.tag-primary {
  background-color: #dbeafe;
  color: #0ea5e9;
}

.tag-success {
  background-color: #d1fae5;
  color: #10b981;
}

.tag-warning {
  background-color: #fef3c7;
  color: #f59e0b;
}

.tag-danger {
  background-color: #fee2e2;
  color: #ef4444;
}

.tag-gray {
  background-color: #f3f4f6;
  color: #6b7280;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 120rpx 32rpx;
}

.empty-icon {
  font-size: 120rpx;
  color: #d1d5db;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #9ca3af;
}

/* 加载状态 */
.loading-container {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 80rpx;
}

/* 分割线 */
.divider {
  height: 2rpx;
  background-color: #e5e7eb;
  margin: 24rpx 0;
}

/* 文本样式 */
.text-primary {
  color: #0ea5e9;
}

.text-muted {
  color: #6b7280;
}

.text-bold {
  font-weight: bold;
}

.text-center {
  text-align: center;
}

/* 间距工具类 */
.mt-16 { margin-top: 16rpx; }
.mt-24 { margin-top: 24rpx; }
.mt-32 { margin-top: 32rpx; }
.mb-16 { margin-bottom: 16rpx; }
.mb-24 { margin-bottom: 24rpx; }
.mb-32 { margin-bottom: 32rpx; }

/* Flex 布局 */
.flex {
  display: flex;
}

.flex-center {
  display: flex;
  justify-content: center;
  align-items: center;
}

.flex-between {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.flex-column {
  display: flex;
  flex-direction: column;
}
