/* pages/output-detail/output-detail.wxss */
.detail-container {
  min-height: 100vh;
  padding-bottom: 120rpx;
  background-color: #f8f9fa;
}

.detail-header {
  background: #ffffff;
  padding: 32rpx;
  border-bottom: 2rpx solid #e5e7eb;
}

.header-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #111827;
  line-height: 1.5;
  margin-bottom: 16rpx;
}

.header-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.meta-text {
  font-size: 28rpx;
  color: #6b7280;
}

.detail-section {
  background: #ffffff;
  padding: 32rpx;
  margin-top: 16rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #111827;
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid #e5e7eb;
}

.info-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24rpx;
}

.info-item {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.info-item.full-width {
  grid-column: 1 / -1;
}

.info-label {
  font-size: 26rpx;
  color: #9ca3af;
}

.info-value {
  font-size: 28rpx;
  color: #111827;
  word-break: break-all;
}

.authors-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.author-item {
  display: flex;
  gap: 12rpx;
  font-size: 28rpx;
  color: #111827;
}

.author-index {
  color: #9ca3af;
  min-width: 48rpx;
}

.author-name {
  flex: 1;
}

.action-section {
  padding: 32rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.review-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.btn-success {
  background-color: #10b981;
  color: #ffffff;
  border: none;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 32rpx;
  font-weight: bold;
}

.btn-success:active {
  background-color: #059669;
}

.btn-warning {
  background-color: #f59e0b;
  color: #ffffff;
  border: none;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 32rpx;
  font-weight: bold;
}

.btn-warning:active {
  background-color: #d97706;
}

.btn-danger {
  background-color: #ef4444;
  color: #ffffff;
  border: none;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 32rpx;
  font-weight: bold;
}

.btn-danger:active {
  background-color: #dc2626;
}
