/* pages/dashboard/dashboard.wxss */
.dashboard-container {
  min-height: 100vh;
  padding-bottom: 120rpx;
}

.dashboard-header {
  background: linear-gradient(135deg, #0ea5e9 0%, #0284c7 100%);
  padding: 48rpx 32rpx;
  color: #ffffff;
}

.lab-info {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.lab-name {
  font-size: 40rpx;
  font-weight: bold;
}

.user-role {
  font-size: 28rpx;
  opacity: 0.9;
}

.stats-section {
  padding: 32rpx;
  margin-top: -48rpx;
}

.stats-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24rpx;
}

.stat-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx 24rpx;
  text-align: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.stat-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #0ea5e9;
  margin-bottom: 8rpx;
}

.stat-value.text-success {
  color: #10b981;
}

.stat-value.text-warning {
  color: #f59e0b;
}

.stat-value.text-muted {
  color: #6b7280;
}

.stat-label {
  font-size: 26rpx;
  color: #6b7280;
}

.recent-section {
  padding: 0 32rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #111827;
}

.section-more {
  font-size: 28rpx;
  color: #0ea5e9;
}

.outputs-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.output-item {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.output-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.output-title {
  flex: 1;
  font-size: 30rpx;
  font-weight: bold;
  color: #111827;
  line-height: 1.4;
}

.output-meta {
  display: flex;
  gap: 24rpx;
  margin-bottom: 8rpx;
}

.meta-item {
  font-size: 26rpx;
  color: #6b7280;
}

.meta-label {
  color: #9ca3af;
}

.output-authors {
  font-size: 26rpx;
  color: #6b7280;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
